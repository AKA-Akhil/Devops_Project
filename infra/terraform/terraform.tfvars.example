kubeconfig_path = "~/.kube/config"
namespace       = "devops-project"

server_image = "ghcr.io/<your-github-username>/devops-project-server:latest"
client_image = "ghcr.io/<your-github-username>/devops-project-client:latest"

github_token  = "replace-with-token"
model_api_key = "replace-with-model-key"
model_provider = "finetuned"
model_name     = "ft:gpt-4o:your-org:devops-analyzer:xxxx"
model_base_url = "https://api.openai.com/v1"
